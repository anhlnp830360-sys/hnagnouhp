SELECT 
    WarehouseID, 
    COUNT(ProductID) AS ProductCount
FROM 
    Instock
GROUP BY 
    WarehouseID
HAVING 
    COUNT(ProductID) = (
        SELECT MAX(SubCount)
        FROM (
            SELECT COUNT(ProductID) AS SubCount 
            FROM Instock 
            GROUP BY WarehouseID
        ) AS SubTable
    );
