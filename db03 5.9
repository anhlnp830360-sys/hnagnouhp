##### db03 5.1
SELECT ProductID, ProductName, UnitPrice
FROM Product
WHERE CategoryID = 'C02';


##### db03 5.9
### đại số quan hệ
Product ⨝ (WarehouseID, ProductID, Quantity) Instock
γ ProductID, SUM(Quantity) → TotalQuantity
### sql
SELECT p.ProductID, p.ProductName, SUM(i.Quantity) AS TotalQuantity
FROM Product p
JOIN Instock i ON p.ProductID = i.ProductID
GROUP BY p.ProductID, p.ProductName
ORDER BY p.ProductID;


##### db03 5.10
### đại số quan hệ (dùng subquery)
γ ProductID, SUM(Quantity) → TotalQuantity (Instock)
### sql (dùng subquery)
SELECT p.ProductID, p.ProductName, SUM(i.Quantity) AS TotalQuantity
FROM Product p
JOIN Instock i ON p.ProductID = i.ProductID
GROUP BY p.ProductID, p.ProductName
HAVING SUM(i.Quantity) = (
    SELECT MAX(TotalQuantity)
    FROM (
        SELECT SUM(Quantity) AS TotalQuantity
        FROM Instock
        GROUP BY ProductID
    ) AS SubQuery
);


##### db03 5.11
### đại số quan hệ
Warehouse ⨝ (CategoryID = CategoryID) Category
### sql
SELECT w.WarehouseID, w.WarehouseAddress, c.CategoryName
FROM Warehouse w
JOIN Category c ON w.CategoryID = c.CategoryID
WHERE NOT EXISTS (
    SELECT 1
    FROM Product p
    WHERE p.CategoryID = w.CategoryID
      AND NOT EXISTS (
          SELECT 1
          FROM Instock i
          WHERE i.WarehouseID = w.WarehouseID
            AND i.ProductID = p.ProductID
      )
);


##### db03 5.12
### đại số quan hệ
π WarehouseID (Warehouse) 
÷
π ProductID (σ CategoryID='C01' (Product))
### sql
SELECT w.WarehouseID, w.WarehouseAddress
FROM Warehouse w
WHERE NOT EXISTS (
    SELECT 1
    FROM Product p
    WHERE p.CategoryID = 'C01'
      AND NOT EXISTS (
          SELECT 1
          FROM Instock i
          WHERE i.WarehouseID = w.WarehouseID
            AND i.ProductID = p.ProductID
      )
);


##### db03 5.19
SELECT p.ProductID, p.ProductName, SUM(i.Quantity) AS TotalQuantity
FROM Product p
JOIN Instock i ON p.ProductID = i.ProductID
GROUP BY p.ProductID, p.ProductName
HAVING SUM(i.Quantity) > 100
ORDER BY TotalQuantity DESC;

