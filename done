SELECT 
    w.WarehouseID, 
    w.WarehouseAddress, 
    SUM(i.Quantity) AS TotalQuantity
FROM 
    Warehouse w
LEFT JOIN 
    Instock i ON w.WarehouseID = i.WarehouseID
GROUP BY 
    w.WarehouseID, 
    w.WarehouseAddress;
5.6
SELECT 
    WarehouseID, 
    SUM(Quantity) AS TotalQuantity
FROM 
    Instock
GROUP BY 
    WarehouseID
HAVING 
    SUM(Quantity) = (
        SELECT MAX(Total)
        FROM (
            SELECT SUM(Quantity) AS Total 
            FROM Instock 
            GROUP BY WarehouseID
        ) AS SubTable
    );
5.7
SELECT 
    w.WarehouseID, 
    w.WarehouseAddress, 
    COUNT(i.ProductID) AS NumberOfProducts
FROM 
    Warehouse w
LEFT JOIN 
    Instock i ON w.WarehouseID = i.WarehouseID
GROUP BY 
    w.WarehouseID, 
    w.WarehouseAddress;
