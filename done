-- =====================================================
-- BUSINESS RULE
-- A warehouse can only store products
-- belonging to its own category.
-- =====================================================

DELIMITER $$

CREATE TRIGGER trg_CheckCategory_Insert
BEFORE INSERT ON Instock
FOR EACH ROW
BEGIN

    DECLARE v_ProductCategory VARCHAR(10);
    DECLARE v_WarehouseCategory VARCHAR(10);

    SELECT CategoryID
    INTO v_ProductCategory
    FROM Product
    WHERE ProductID = NEW.ProductID;

    SELECT CategoryID
    INTO v_WarehouseCategory
    FROM Warehouse
    WHERE WarehouseID = NEW.WarehouseID;

    IF v_ProductCategory <> v_WarehouseCategory THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT =
        'Product category must match warehouse category';
    END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_CheckCategory_Update
BEFORE UPDATE ON Instock
FOR EACH ROW
BEGIN

    DECLARE v_ProductCategory VARCHAR(10);
    DECLARE v_WarehouseCategory VARCHAR(10);

    SELECT CategoryID
    INTO v_ProductCategory
    FROM Product
    WHERE ProductID = NEW.ProductID;

    SELECT CategoryID
    INTO v_WarehouseCategory
    FROM Warehouse
    WHERE WarehouseID = NEW.WarehouseID;

    IF v_ProductCategory <> v_WarehouseCategory THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT =
        'Product category must match warehouse category';
    END IF;

END$$

