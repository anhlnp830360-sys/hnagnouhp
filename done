5.10

SELECT p.ProductID, p.ProductName, SUM(i.Quantity) AS TotalQuantity
FROM Product p
JOIN Instock i ON p.ProductID = i.ProductID
GROUP BY p.ProductID, p.ProductName
HAVING SUM(i.Quantity) = (
    SELECT MAX(TotalQuantity)
    FROM (
        SELECT SUM(Quantity) AS TotalQuantity
        FROM Instock
        GROUP BY ProductID
    ) AS SubQuery
);


